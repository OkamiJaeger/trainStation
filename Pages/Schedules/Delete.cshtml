@page
@model trainStation.Pages.Schedules.DeleteModel

@{
    ViewData["Title"] = "Delete Schedule";
}
<div class="bg-opacity-50 bg-light p-3">
<h1>Delete Schedule</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Schedule.Arrival)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Schedule.Arrival)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Schedule.Departure)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Schedule.Departure)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Schedule.Platform)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Schedule.Platform)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Schedule.Train)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Schedule.Train.Company)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Schedule.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-page="./Index">Back to List</a>
    </form>
</div>
</div>
