@page
@model trainStation.Pages.Schedules.IndexModel

@{
    ViewData["Title"] = "Station Schedule";
}

<h1>Station Schedule</h1>

<p>
    <a style="font-size:1.3em;" asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Schedule[0].Train)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Schedule[0].Platform)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Schedule[0].Arrival)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Schedule[0].Departure)
            </th>
            <th>&nbsp;</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Schedule) {
        <tr>            
            <td>
                @Html.DisplayFor(modelItem => item.Train.Company)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Platform)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Arrival)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Departure)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
