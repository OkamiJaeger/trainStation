@page
@model trainStation.Pages.Schedules.EditModel

@{
    ViewData["Title"] = "Edit Schedule";
}
<div class="bg-opacity-50 bg-light p-3">
<h1>Edit Schedule</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Schedule.Id" />
            <div class="form-group">
                <label asp-for="Schedule.TrainID" class="control-label"></label>
                <select asp-for="Schedule.TrainID" class="form-control" asp-items="ViewBag.TrainID">
                    <option value="">-- Select a Train --</option>
                </select>
                <span asp-validation-for="Schedule.TrainID" class="text-danger"></span>
            </div>
            <div class="form-group">
                <div class="form-group">
                    <label asp-for="Schedule.Platform" class="control-label"></label>
                    <select asp-for="Schedule.Platform" class="form-control" asp-items="Html.GetEnumSelectList<trainStation.Model.PlatformType>()">
                        <option value="">-- Select a Platform --</option>
                    </select>
                    <span asp-validation-for="Schedule.Platform" class="text-danger"></span>
             </div>
<span class="text-danger">*</span>
                <label asp-for="Schedule.Arrival" class="control-label"></label>
                <input asp-for="Schedule.Arrival" class="form-control" aria-required="true"/>
                <span asp-validation-for="Schedule.Arrival" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Schedule.Departure" class="control-label"></label>
                <input asp-for="Schedule.Departure" class="form-control" />
                <span asp-validation-for="Schedule.Departure" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-outline-dark" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
